{
  "name": "open-mt2",
  "version": "1.0.0",
  "description": "",
  "main": "src/main.js",
  "scripts": {
    "dev:auth": "cross-env LOG_LEVEL=info tsnd -r tsconfig-paths/register --transpile-only --respawn --ignore-watch node_modules --watch src/auth --env-file=.env src/auth/main.ts",
    "dev:game": "cross-env LOG_LEVEL=info tsnd -r tsconfig-paths/register --transpile-only --respawn --ignore-watch node_modules --watch src/game --env-file=.env src/game/main.ts",
    "dev:auth:debug": "cross-env LOG_LEVEL=debug tsnd -r tsconfig-paths/register --transpile-only --respawn --ignore-watch node_modules --watch src/auth --env-file=.env src/auth/main.ts",
    "dev:game:debug": "cross-env LOG_LEVEL=debug tsnd -r tsconfig-paths/register --transpile-only --respawn --ignore-watch node_modules --watch src/game --env-file=.env src/game/main.ts",
    "auth": "node --env-file=.env dist/auth/main.js",
    "game": "node --env-file=.env dist/game/main.js",
    "migrate": "cross-env tsnd -r tsconfig-paths/register --env-file=.env tools/database/migrate.ts",
    "format": "prettier -w {src,test}/**/*.ts",
    "prepare": "husky || exit 0",
    "lint:fix": "eslint --fix {src,test}/**/*.ts",
    "test:unit": "mocha -r tsconfig-paths/register --config test/.mocharc.unit.json --exit",
    "test:integration": "node --env-file=.env ./node_modules/mocha/bin/mocha --env-file=.env -r tsconfig-paths/register --config test/.mocharc.integration.json --exit",
    "test:ping": "node --env-file=.env -r ts-node/register -r tsconfig-paths/register test/performance/pingFlow.ts",
    "test:performance": "node --env-file=.env -r ts-node/register -r tsconfig-paths/register test/performance/index.ts",
    "test:coverage": "c8 npm run test:unit",
    "docker:all": "docker-compose -f docker-compose.yml up -d",
    "docker:dep": "docker-compose -f docker-compose.dep.yml up -d",
    "generate:doc": "node tools/doc/docGenerator.js",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json"
  },
  "author": "Willian Marques (willian.goncalves4@gmail.com)",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@types/sinon": "^21.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "eslint": "^10.4.0",
    "expectations": "^1.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "dependencies": {
    "awilix": "^13.0.3",
    "bcryptjs": "^3.0.3",
    "cross-env": "^10.1.0",
    "mysql2": "^3.22.3",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "sinon": "^22.0.0",
    "winston": "^3.19.0"
  },
  "mocha": {
    "require": "expectations"
  }
}
